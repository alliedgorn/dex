#!/usr/bin/env bash
# karo-search — convenience wrapper for the local RAG search.
#
# Usage:
#   karo-search "limiz convo"
#   karo-search "Hotel Derby" --top 5
#   karo-search "stew belly" --type brain
#   karo-search "fluff name birth" --json
#
# Activates the local venv automatically.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PYTHON="$SCRIPT_DIR/.venv/bin/python"
SEARCH_PY="$SCRIPT_DIR/search.py"

if [ ! -x "$VENV_PYTHON" ]; then
  echo "ERROR: venv not found at $SCRIPT_DIR/.venv — run scripts/rag/setup.sh first" >&2
  exit 1
fi

if [ ! -f "$SEARCH_PY" ]; then
  echo "ERROR: search.py not found at $SEARCH_PY" >&2
  exit 1
fi

exec "$VENV_PYTHON" "$SEARCH_PY" "$@"
